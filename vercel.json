{
  "version": 2,
  "functions": {
    "www/index.php": {
      "runtime": "vercel-php"
    },
    "www/login.php": {
      "runtime": "vercel-php"
    },
    "www/signup.php": {
      "runtime": "vercel-php"
    },
    "api/**/*.php": {
      "runtime": "vercel-php"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.php"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/www/assets/$1"
    },
    {
      "src": "/login",
      "dest": "/www/login.php"
    },
    {
      "src": "/signup",
      "dest": "/www/signup.php"
    },
    {
      "src": "/(.*)",
      "dest": "/www/index.php"
    }
  ]
}
