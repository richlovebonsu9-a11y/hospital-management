{
  "version": 2,
  "functions": {
    "public/index.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "public/login.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "public/signup.php": {
      "runtime": "vercel-php@0.7.1"
    },
    "api/**/*.php": {
      "runtime": "vercel-php@0.7.1"
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.php"
    },
    {
      "src": "/assets/(.*)",
      "dest": "/public/assets/$1"
    },
    {
      "src": "/login",
      "dest": "/public/login.php"
    },
    {
      "src": "/signup",
      "dest": "/public/signup.php"
    },
    {
      "src": "/(.*)",
      "dest": "/public/index.php"
    }
  ]
}
