{
  "version": 2,
  "builds": [
    {
      "src": "www/**/*.php",
      "use": "vercel-php@0.7.1"
    },
    {
      "src": "api/**/*.php",
      "use": "vercel-php@0.7.1"
    }
  ],
  "routes": [
    {
      "src": "/assets/(.*)",
      "dest": "/www/assets/$1"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/$1.php"
    },
    {
      "src": "/login",
      "dest": "/www/login.php"
    },
    {
      "src": "/signup",
      "dest": "/www/signup.php"
    },
    {
      "src": "/(.*)",
      "dest": "/www/index.php"
    }
  ]
}
